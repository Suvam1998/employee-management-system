# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/ems

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d
# In production (HTTPS, cross-site cookie) set COOKIE_SECURE=true
COOKIE_SECURE=false

# CORS: comma-separated list of allowed frontend origins.
# Any *.vercel.app origin is also allowed automatically.
CLIENT_URL=http://localhost:3000

# Set to true on the hosted backend to auto-seed demo data when the DB is empty
SEED_ON_START=false

# Seed super admin
SEED_ADMIN_EMAIL=admin@ems.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_NAME=Super Admin
